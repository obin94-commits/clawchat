generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Thread {
  id                    String       @id @default(cuid())
  title                 String       @default("Untitled")
  parentThreadId        String?
  branchedFromMessageId String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  messages              Message[]
  costEntries           CostEntry[]
  memoryChips           MemoryChip[]
  parentThread          Thread?      @relation("ThreadBranches", fields: [parentThreadId], references: [id])
  childThreads          Thread[]     @relation("ThreadBranches")

  @@index([updatedAt])
  @@index([parentThreadId])
}

model CostEntry {
  id        String   @id @default(cuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  agentId   String?
  tokens    Int      @default(0)
  costUsd   Float    @default(0)
  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
}

model Message {
  id          String   @id @default(cuid())
  threadId    String
  thread      Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role        String   @default("USER")   // USER | AGENT | SYSTEM | TOOL
  content     String
  displayType String   @default("VISIBLE") // VISIBLE | COLLAPSED | HIDDEN | GHOST
  metadata    String?  // JSON string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([threadId, createdAt])
}

model MemoryChip {
  id        String   @id @default(cuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  text      String
  metadata  String?  // JSON string
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
}
