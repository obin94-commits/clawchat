# ClawChat server environment variables
# Copy to .env and fill in values

# Server
SERVER_PORT=3001

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL (production default):
DATABASE_URL="postgresql://postgres:password@localhost:5432/clawchat"

# SQLite fallback for local dev (no Postgres required):
#   1. Change schema.prisma datasource provider to "sqlite"
#   2. Set: DATABASE_URL="file:./dev.db"
#   3. Run: pnpm prisma migrate dev

# Auth — if set, every HTTP request must carry: Authorization: Bearer <key>
# Leave unset (or empty) to run in open dev mode (no auth)
CLAWCHAT_API_KEY=

# Memory (mem0 + Qdrant)
QDRANT_URL=http://localhost:6333
OPENAI_API_KEY=

# OpenClaw agent relay
OPENCLAW_API_URL=http://localhost:18789/v1/chat/completions
OPENCLAW_API_TOKEN=
