# ClawChat Server — environment variables
# Copy to .env and fill in real values

# Port the HTTP/WS server listens on
SERVER_PORT=3001

# Qdrant vector database URL (mem0 backend)
QDRANT_URL=http://100.93.134.22:6333

# OpenAI API key — used for text-embedding-3-small
OPENAI_API_KEY=sk-...

# Prisma database URL (SQLite for local dev, Postgres for production)
DATABASE_URL=file:./dev.db
