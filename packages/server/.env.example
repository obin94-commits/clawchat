# ClawChat server environment variables
# Copy to .env and fill in values

# Server
SERVER_PORT=3001

# Database (SQLite by default — change to postgres:// for production)
DATABASE_URL="file:./dev.db"

# Auth — if set, every HTTP request must carry: Authorization: Bearer <key>
# Leave unset (or empty) to run in open dev mode (no auth)
CLAWCHAT_API_KEY=

# Memory (mem0 + Qdrant)
QDRANT_URL=http://localhost:6333
OPENAI_API_KEY=
