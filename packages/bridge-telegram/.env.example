# Telegram Bridge — .env.example
# Copy to packages/bridge-telegram/.env and fill in real values

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ClawChat server URL (where messages will be relayed)
CLAWCHAT_SERVER_URL=http://localhost:3001

# Telegram Chat ID to monitor (can be a group or user chat ID)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: API key if CLAWCHAT_API_KEY is set on the server
CLAWCHAT_API_KEY=
