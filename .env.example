# ClawChat — root .env.example
# Copy to packages/server/.env and fill in real values

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL (production / default)
DATABASE_URL="postgresql://postgres:password@localhost:5432/clawchat"

# SQLite fallback for local dev (change provider in schema.prisma too):
# DATABASE_URL="file:./dev.db"

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=3001

# Optional: require this Bearer token on all requests.
# Leave empty to run in open dev mode (no auth).
CLAWCHAT_API_KEY=

# ─── mem0 / Qdrant ────────────────────────────────────────────────────────────
MEM0_API_KEY=
QDRANT_URL=http://localhost:6333

# ─── OpenClaw bridge ─────────────────────────────────────────────────────────
# Verified: gateway uses WebSocket RPC protocol (type:req/res/event).
# Connect to ws://<host> — no /ws suffix.
OPENCLAW_WS=ws://100.102.5.72:18789
OPENCLAW_TOKEN=698900e334ca63800944174b5d1617cd53f7dc0b4a211794
OPENCLAW_SESSION=main

# Base URL of this ClawChat server (used by the bridge to post messages)
CLAWCHAT_URL=http://localhost:3001

# ─── Client (Expo) ────────────────────────────────────────────────────────────
EXPO_PUBLIC_SERVER_URL=http://localhost:3001
EXPO_PUBLIC_API_KEY=
